{
  "name": "zero-to-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true}); try{require('fs').rmSync('node_modules/.cache',{recursive:true,force:true})}catch(e){}\"",
    "dev:clean": "npm run clean && npm run dev",
    "dev": "portless run --force next dev",
    "dev:direct": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.84",
    "@ai-sdk/openai": "^3.0.49",
    "@ai-sdk/react": "^3.0.144",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.0",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.142",
    "framer-motion": "^11.0.0",
    "geist": "^1.3.0",
    "lucide-react": "^0.460.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.0",
    "unicode-animations": "^1.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.1",
    "portless": "^0.9.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  }
}
